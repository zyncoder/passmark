# Cloudflare static-asset headers. These apply to files served directly by
# the Worker's ASSETS binding (i.e. anything in /public/* and the static
# build output). Headers set in next.config.ts also apply to SSR responses,
# but for purely static assets we set them here too to be safe.

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /
  Content-Type: application/javascript

/manifest.webmanifest
  Cache-Control: public, max-age=3600
  Content-Type: application/manifest+json

/*.png
  Cache-Control: public, max-age=86400

# Defence-in-depth: same security headers as next.config.ts, in case a static
# response bypasses the Next handler.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(), geolocation=()
